<Page x:Class="手术机器人上位机程序.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:手术机器人上位机程序"
      mc:Ignorable="d" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      TextElement.FontWeight="Regular"
      TextElement.FontSize="13"
      TextOptions.TextFormattingMode="Ideal"
      TextOptions.TextRenderingMode="Auto"
      Background="{DynamicResource MaterialDesignPaper}"
      FontFamily="{DynamicResource MaterialDesignFont}"
      Title="Page2">

    <Grid Margin="0,10,10,10" x:Name="MainGrid" Width="1920" Height="1080">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="250"/>
        </Grid.RowDefinitions>
        <materialDesign:Card Width="600" Grid.Column="1"  Grid.Row="1">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="0.3*"/>
                    <ColumnDefinition Width="1.7*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="机械臂1控制" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="4" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="80"/>
                <TextBlock Text="The 1st Robotics Arm Turning" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="4" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="40"/>
                <Button x:Name="Motor1_Enable" Click="Motor1_Enable_Click" Grid.Column="0" Grid.Row="3" Height="120" Width="250" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" Background="Gray">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="激活" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="48"/>
                        <TextBlock Text="Enable" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="36"/>
                    </Grid>
                </Button>
                <Button x:Name="Motor1_Disnable" Click="Motor1_Disnable_Click" Grid.ColumnSpan="2" Grid.Column="2" Grid.Row="3" Height="120" Width="250"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" Background="Gray">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="禁用" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="48"/>
                        <TextBlock Text="Disable" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="36"/>
                    </Grid>
                </Button>
                <Button x:Name="Motor1_Left" MouseLeftButtonDown="Motor1_Left_MouseLeftButtonDown" MouseLeftButtonUp="Motor1_Left_MouseLeftButtonUp" Grid.Column="0" Grid.Row="5" Height="100" Width="100" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="180.00"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" Height="67" Width="76"/>
                </Button>
                <Button x:Name="Motor1_Right" MouseLeftButtonDown="Motor1_Right_MouseLeftButtonDown" Grid.ColumnSpan="2" MouseLeftButtonUp="Motor1_Right_MouseLeftButtonUp" Grid.Column="2" Grid.Row="5" Height="100" Width="100" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">   
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" Height="67" Width="76"/>
                </Button>
            </Grid>
        </materialDesign:Card>
        <materialDesign:Card Width="600" Grid.Column="3"  Grid.Row="1">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="0.3*"/>
                    <ColumnDefinition Width="1.7*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="机械臂2控制" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="4" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="80"/>
                <TextBlock Text="The 2nd Robotics Arm Turning" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="4" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="40"/>
                <Button x:Name="Motor2_Enable" Click="Motor2_Enable_Click" Grid.Column="0" Grid.Row="3" Height="120" Width="250" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" Background="Gray">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="激活" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="48"/>
                        <TextBlock Text="Enable" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="36"/>
                    </Grid>
                </Button>
                <Button x:Name="Motor2_Disnable" Click="Motor2_Disnable_Click" Grid.ColumnSpan="2" Grid.Column="2" Grid.Row="3" Height="120" Width="250"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" Background="Gray">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="禁用" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="48"/>
                        <TextBlock Text="Disable" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="36"/>
                    </Grid>
                </Button>
                <Button x:Name="Motor2_Left" MouseLeftButtonDown="Motor2_Left_MouseLeftButtonDown" MouseLeftButtonUp="Motor2_Left_MouseLeftButtonUp" Grid.Column="0" Grid.Row="5" Height="100" Width="100" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="180.00"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" Height="67" Width="76"/>
                </Button>
                <Button x:Name="Motor2_Right" MouseLeftButtonDown="Motor2_Right_MouseLeftButtonDown" Grid.ColumnSpan="2" MouseLeftButtonUp="Motor2_Right_MouseLeftButtonUp" Grid.Column="2" Grid.Row="5" Height="100" Width="100" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" Height="67" Width="76"/>
                </Button>
            </Grid>
        </materialDesign:Card>
        <materialDesign:Card Width="600" Grid.Column="5"  Grid.Row="1">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="0.3*"/>
                    <ColumnDefinition Width="1.7*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="机械臂3控制" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="4" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="80"/>
                <TextBlock Text="The 3rd Robotics Arm Turning" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="4" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="40"/>
                <Button x:Name="Motor3_Enable" Click="Motor3_Enable_Click" Grid.Column="0" Grid.Row="3" Height="120" Width="250" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" Background="Gray">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="激活" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="48"/>
                        <TextBlock Text="Enable" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="36"/>
                    </Grid>
                </Button>
                <Button x:Name="Motor3_Disnable" Click="Motor3_Disnable_Click" Grid.ColumnSpan="2" Grid.Column="2" Grid.Row="3" Height="120" Width="250"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" Background="Gray">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="禁用" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="48"/>
                        <TextBlock Text="Disable" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="36"/>
                    </Grid>
                </Button>
                <Button x:Name="Motor3_Left" MouseLeftButtonDown="Motor3_Left_MouseLeftButtonDown" MouseLeftButtonUp="Motor3_Left_MouseLeftButtonUp" Grid.Column="0" Grid.Row="5" Height="100" Width="100" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="180.00"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" Height="67" Width="76"/>
                </Button>
                <Button x:Name="Motor3_Right" MouseLeftButtonDown="Motor3_Right_MouseLeftButtonDown" Grid.ColumnSpan="2" MouseLeftButtonUp="Motor3_Right_MouseLeftButtonUp" Grid.Column="2" Grid.Row="5" Height="100" Width="100" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" Height="67" Width="76"/>
                </Button>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card   Grid.Column="1"  Grid.ColumnSpan="5" Grid.Row="3">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Block.TextAlignment="Center" Text="速度设置  &#x000A;(Speed Setting)" Grid.Column="0"  VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="52"/>
                <ComboBox Name="Motor1_SpeedCombo" Width="180" Grid.Column="0" Grid.Row="4" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="30" DropDownClosed="Motor1_SpeedCombo_DropDownClosed" SelectionChanged="Motor1_SpeedCombo_SelectionChanged">
                    <ComboBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel>
                            </VirtualizingStackPanel>
                        </ItemsPanelTemplate>
                    </ComboBox.ItemsPanel>
                </ComboBox>
                <Button x:Name="return" FontWeight="Bold" Click="return_Click" HorizontalAlignment="Center" Height="160" Width="400" FontSize="30"  Grid.Column="2" VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="返回主界面" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="48"/>
                        <TextBlock Text="Return to Main Page" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="36"/>
                    </Grid>
                </Button>
                <Button x:Name="advanced" FontWeight="Bold" Click="advanced_Click" HorizontalAlignment="Center" Height="160" Width="400" FontSize="30" Grid.Column="4"  VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="高级" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="48"/>
                        <TextBlock Text="Advanced" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="36"/>
                    </Grid>
                </Button>
            </Grid>
        </materialDesign:Card>

    </Grid>
</Page>

<Page x:Class="手术机器人上位机程序.Page4"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:local="clr-namespace:手术机器人上位机程序"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"  
        Title="云台摄像头控制">
    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="10"/>

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!--<Image HorizontalAlignment="Center" VerticalAlignment="Bottom" Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="3"/>-->

        <TextBlock Text="云台摄像头控制面板 PTZ Camera Pannel" HorizontalAlignment="Center" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="7" FontSize="80"/>

        <materialDesign:Card Width="600" Grid.Column="1" Grid.ColumnSpan="1" Grid.Row="1" Grid.RowSpan="2">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="云台控制 (PTZ Control)" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="11" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="40"/>
                <Button x:Name="PtzSet" Click="PtzSet_Click" Content="参数设置(PtzSet)" Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="15" Height="60" Width="250" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="28"/>
                <Button x:Name="PtzGet" Click="PtzGet_Click" Content="参数获取(PtzGet)" Grid.ColumnSpan="5" Grid.Column="6" Grid.Row="15" Height="60" Width="250"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="28"/>
                <TextBlock Text="速度设置" Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="8" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <ComboBox Name="PTZ_SpeedCombo" Width="180" Grid.Column="6" Grid.ColumnSpan="5" Grid.Row="8" FontSize="30" DropDownClosed="PTZ_SpeedCombo_DropDownClosed" SelectionChanged="PTZ_SpeedCombo_SelectionChanged" Margin="52,0" VerticalAlignment="Stretch">
                    <ComboBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel>
                            </VirtualizingStackPanel>
                        </ItemsPanelTemplate>
                    </ComboBox.ItemsPanel>
                </ComboBox>
                <TextBlock Text="操作类型" Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="12" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <ComboBox Name="Operate_TypeCombo" Width="360" Grid.Column="4" Grid.ColumnSpan="7" Grid.Row="12" FontSize="30" DropDownClosed="Operate_TypeCombo_DropDownClosed" SelectionChanged="Operate_TypeComboCombo_SelectionChanged">
                    <ComboBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel>
                            </VirtualizingStackPanel>
                        </ItemsPanelTemplate>
                    </ComboBox.ItemsPanel>
                </ComboBox>
                <TextBlock Text="P:" Grid.Column="0" Grid.ColumnSpan="1" Grid.Row="10" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <TextBox Name="P_Text" Width="60" Grid.Column="2" Grid.Row="10" FontSize="30"  TextChanged="P_Text_TextChanged"/>
                <TextBlock Text="T:" Grid.Column="4" Grid.ColumnSpan="1" Grid.Row="10" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <TextBox Name="T_Text" Width="60" Grid.Column="6" Grid.Row="10" FontSize="30"  TextChanged="T_Text_TextChanged"/>
                <TextBlock Text="Z:" Grid.Column="8" Grid.ColumnSpan="1" Grid.Row="10" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <TextBox Name="Z_Text" Width="60" Grid.Column="10" Grid.Row="10" FontSize="30"  TextChanged="T_Text_TextChanged"/>
                <Button x:Name="Left" MouseLeftButtonDown="Left_MouseLeftButtonDown" MouseLeftButtonUp="Left_MouseLeftButtonUp" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="3" Grid.RowSpan="3" Height="100" Width="100" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="180.00"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" Height="67" Width="76"/>
                </Button>
                <Button x:Name="Right" MouseLeftButtonDown="Right_MouseLeftButtonDown" Grid.ColumnSpan="3" MouseLeftButtonUp="Right_MouseLeftButtonUp" Grid.Column="4" Grid.Row="3" Grid.RowSpan="3" Height="100" Width="100" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" Height="67" Width="76"/>
                </Button>
                <Button x:Name="Up" MouseLeftButtonDown="Up_MouseLeftButtonDown" Grid.ColumnSpan="3" MouseLeftButtonUp="Up_MouseLeftButtonUp" Grid.Column="2" Grid.Row="1" Grid.RowSpan="3" Height="100" Width="100" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="270.00"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" Height="67" Width="76"/>
                </Button>
                <Button x:Name="Down" MouseLeftButtonDown="Down_MouseLeftButtonDown" Grid.ColumnSpan="3" MouseLeftButtonUp="Down_MouseLeftButtonUp" Grid.Column="2" Grid.Row="5" Grid.RowSpan="3" Height="100" Width="100" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="90.00"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" Height="67" Width="76"/>
                </Button>
                <Button x:Name="ZoomOut" MouseLeftButtonDown="ZoomOut_MouseLeftButtonDown" Grid.ColumnSpan="3" MouseLeftButtonUp="ZoomOut_MouseLeftButtonUp" Grid.Column="8" Grid.Row="4" Grid.RowSpan="4" Height="100" Width="100" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Minus" HorizontalAlignment="Center" Height="67" Width="76"/>
                </Button>
                <Button x:Name="ZoomIn" MouseLeftButtonDown="ZoomIn_MouseLeftButtonDown" Grid.ColumnSpan="3" MouseLeftButtonUp="ZoomIn_MouseLeftButtonUp" Grid.Column="8" Grid.Row="1" Grid.RowSpan="4" Height="100" Width="100" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Plus" HorizontalAlignment="Center" Height="67" Width="76"/>
                </Button>
            </Grid>
        </materialDesign:Card>
        <!--<Image x:Name="My_image" Grid.Column="3"  Grid.Row="1" Source="JPEG_test.jpg" />-->
        <WindowsFormsHost Width="960" Height="540" Grid.Row="1" Grid.Column="3" HorizontalAlignment="Center" Margin="10,10,0,0" VerticalAlignment="Center" >
            <wf:PictureBox x:Name="RealPlayWnd" BackColor="Black"></wf:PictureBox>
        </WindowsFormsHost>
        <materialDesign:Card   Grid.Column="3"  Grid.Row="2">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="Login" Click="Login_Click" Content="登录(Login)" Grid.Column="0" Height="60" Width="220" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <Button x:Name="Preview" Click="Preview_Click" Content="预览(Preview)" Grid.Column="2" Height="60" Width="220" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <Button x:Name="Jpeg" Click="Jpeg_Click" Content="抓图(Capture)" Grid.Column="4" Height="60" Width="220" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <Button x:Name="Record" Click="Record_Click" Content="录像(Record)" Grid.Column="6" Height="60" Width="220" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <Button x:Name="release" Click="Record_Click" Content="释放资源" Grid.Column="8" Height="60" Width="220" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
            </Grid>
        </materialDesign:Card>
        <materialDesign:Card  Grid.Column="0" Grid.ColumnSpan="4"  Grid.Row="4">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="return" Content="返回主界面 (Return the main page)" FontWeight="Bold" Click="return_Click" HorizontalAlignment="Center" Height="80" FontSize="30"  Grid.Column="0" VerticalAlignment="Center"/>
                <Button x:Name="switch" Content="切换至辅助视角摄像头" FontWeight="Bold" Click="switch_Click" HorizontalAlignment="Center" Height="80" FontSize="30"  Grid.Column="2" VerticalAlignment="Center"/>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>

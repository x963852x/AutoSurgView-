<Window x:Class="手术机器人上位机程序.Auto_up_and_down"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:手术机器人上位机程序"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="NoResize"
        Title="自动升降" Height="800" Width="1250">
    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <TextBlock Text="请确定机械臂高度" Block.TextAlignment="Center" Grid.Row="1"  Grid.ColumnSpan="3" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="80"/>
        <TextBlock Text="Please Confirm Robotics Arm Deploying Heught &#x000A;此设定高度为机械臂部署时下边缘的高度" Block.TextAlignment="Center" Grid.Row="3"  Grid.ColumnSpan="3" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="50"/>
        <TextBlock Text="部署高度(cm) &#x000A;Deploying Height" Block.TextAlignment="Center" Grid.Row="5"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="60"/>
        <TextBox x:Name="HeightBox"  Grid.Column="2" Grid.Row="5"  VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="60" Width="300" MouseEnter="HeightBox_MouseEnter" Margin="80,0,0,0" />
        <Button x:Name="AutoMove" Grid.Column="0" Grid.Row="7"  Height="150" Width="600" FontSize="60" Content="自动上升 &#x000A;Auto Move" Block.TextAlignment="Center" FontWeight="Bold" Cursor="Hand" />
        <Button x:Name="cancel" Content="取消  &#x000A;Cancel" Block.TextAlignment="Center" Grid.Row="7"  Height="150" Width="400" Grid.Column="2"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="60" FontWeight="Bold" Click="cancel_Click" Cursor="Hand"/>
    </Grid>
</Window>

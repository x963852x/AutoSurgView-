<Page x:Class="手术机器人上位机程序.Page6"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:sharpGL="clr-namespace:SharpGL.WPF;assembly=SharpGL.WPF"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:手术机器人上位机程序"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page1">

    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="6*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>

        <sharpGL:OpenGLControl
            Grid.Row="1"
            Grid.Column="1"
            OpenGLDraw="OpenGLControl_OpenGLDraw"
            OpenGLInitialized="OpenGLControl_OpenGLInitialized"
            RenderContextType="FBO" Loaded="OpenGLControl_Loaded" />

        <materialDesign:Card Grid.Row="1" Grid.Column="3" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>

                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>

                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>

                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>

                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="机械臂1" Grid.Column="0" Grid.Row="0"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <TextBlock Name="joint_1_text" Text="0°" Grid.Column="2" Grid.Row="0"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <Button x:Name="Motor1_Enable" Click="Motor1_Enable_Click" Content="激活(Enable)" Grid.Column="0" Grid.Row="2" Height="40" Width="200" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Background="Gray"/>
                <Button x:Name="Motor1_Disnable" Click="Motor1_Disnable_Click" Content="禁用(Disable)" Grid.Column="2" Grid.Row="2" Height="40" Width="200"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Background="Gray"/>
                <Button x:Name="Motor1_Left" MouseLeftButtonDown="Motor1_Left_MouseLeftButtonDown" MouseLeftButtonUp="Motor1_Left_MouseLeftButtonUp" Grid.Column="0" Grid.Row="4" Height="60" Width="60" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="180.00"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" VerticalAlignment="Center" Height="50" Width="60"/>
                </Button>
                <Button x:Name="Motor1_Right" MouseLeftButtonDown="Motor1_Right_MouseLeftButtonDown"  MouseLeftButtonUp="Motor1_Right_MouseLeftButtonUp" Grid.Column="2" Grid.Row="4" Height="60" Width="60" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" VerticalAlignment="Center" Height="50" Width="60"/>
                </Button>

                <TextBlock Text="机械臂2" Grid.Column="0" Grid.Row="6"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <TextBlock Name="joint_2_text" Text="0°" Grid.Column="2" Grid.Row="6"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <Button x:Name="Motor2_Enable" Click="Motor2_Enable_Click" Content="激活(Enable)" Grid.Column="0" Grid.Row="8" Height="40" Width="200" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Background="Gray"/>
                <Button x:Name="Motor2_Disnable" Click="Motor2_Disnable_Click" Content="禁用(Disable)" Grid.Column="2" Grid.Row="8" Height="40" Width="200"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Background="Gray"/>
                <Button x:Name="Motor2_Left" MouseLeftButtonDown="Motor2_Left_MouseLeftButtonDown" MouseLeftButtonUp="Motor2_Left_MouseLeftButtonUp" Grid.Column="0" Grid.Row="10" Height="60" Width="60" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="180.00"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" VerticalAlignment="Center" Height="50" Width="60"/>
                </Button>
                <Button x:Name="Motor2_Right" MouseLeftButtonDown="Motor2_Right_MouseLeftButtonDown"  MouseLeftButtonUp="Motor2_Right_MouseLeftButtonUp" Grid.Column="2" Grid.Row="10" Height="60" Width="60" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" VerticalAlignment="Center" Height="50" Width="60"/>
                </Button>

                <TextBlock Text="机械臂3" Grid.Column="0" Grid.Row="12"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <TextBlock Name="joint_3_text" Text="0°" Grid.Column="2" Grid.Row="12"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>
                <Button x:Name="Motor3_Enable" Click="Motor3_Enable_Click" Content="激活(Enable)" Grid.Column="0" Grid.Row="14" Height="40" Width="200" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Background="Gray"/>
                <Button x:Name="Motor3_Disnable" Click="Motor3_Disnable_Click" Content="禁用(Disable)" Grid.Column="2" Grid.Row="14" Height="40" Width="200"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Background="Gray"/>
                <Button x:Name="Motor3_Left" MouseLeftButtonDown="Motor3_Left_MouseLeftButtonDown" MouseLeftButtonUp="Motor3_Left_MouseLeftButtonUp" Grid.Column="0" Grid.Row="16" Height="60" Width="60" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="180.00"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" VerticalAlignment="Center" Height="50" Width="60"/>
                </Button>
                <Button x:Name="Motor3_Right" MouseLeftButtonDown="Motor3_Right_MouseLeftButtonDown"  MouseLeftButtonUp="Motor3_Right_MouseLeftButtonUp" Grid.Column="2" Grid.Row="16" Height="60" Width="60" Style="{StaticResource MaterialDesignIconButton}" ToolTip="MaterialDesignIconButton" Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <materialDesign:PackIcon Kind="Play" HorizontalAlignment="Center" VerticalAlignment="Center" Height="50" Width="60"/>
                </Button>

                <TextBlock Text="调节速度设置 &#x000A;Deploying Speed Setting" Block.TextAlignment="Center" Grid.Column="0"  Grid.Row="18" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="26"/>
                <ComboBox Name="Motor1_SpeedCombo" Width="180" Grid.Column="2" Grid.Row="18" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" DropDownClosed="Motor1_SpeedCombo_DropDownClosed" SelectionChanged="Motor1_SpeedCombo_SelectionChanged">
                    <ComboBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel>
                            </VirtualizingStackPanel>
                        </ItemsPanelTemplate>
                    </ComboBox.ItemsPanel>
                </ComboBox>

                <TextBlock Text="云台电机1 &#x000A;Motor1 Angle" Block.TextAlignment="Center" Grid.Column="0" Grid.Row="20"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="26"/>
                <TextBlock Name="joint_4_text" Text="0°" Grid.Column="2" Grid.Row="20"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>

                <TextBlock Text="云台电机2 &#x000A;Motor2 Angle" Block.TextAlignment="Center" Grid.Column="0" Grid.Row="22"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="26"/>
                <TextBlock Name="joint_5_text" Text="0°" Grid.Column="2" Grid.Row="22"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>

                <TextBlock Text="立柱高度 &#x000A;Pillar Heigth" Block.TextAlignment="Center" Grid.Column="0" Grid.Row="24"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="26"/>
                <TextBlock Name="joint_lizhu_text" Text="0cm" Grid.Column="2" Grid.Row="24"  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30"/>


            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="return" Content="返回主界面 &#x000A;Return to Main Page" Block.TextAlignment="Center" FontWeight="Bold" Click="return_Click" HorizontalAlignment="Center" Height="100" FontSize="30" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
                <Button x:Name="basic" Content="基本 &#x000A;Return to Basic Setting" Block.TextAlignment="Center" FontWeight="Bold" Click="basic_Click" HorizontalAlignment="Center" Height="100" FontSize="30" Grid.Row="0" Grid.Column="4"  VerticalAlignment="Center"/>
            </Grid>
        </materialDesign:Card>


    </Grid>
</Page>
